{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Event",
  "description": "A single event entry in events.jsonl",
  "type": "object",
  "properties": {
    "timestamp": { "type": "string", "format": "date-time" },
    "type": {
      "type": "string",
      "enum": ["session_start", "session_end", "interaction", "tool_call", "error", "mood_change"]
    },
    "data": { "type": "object" }
  },
  "required": ["timestamp", "type", "data"]
}
