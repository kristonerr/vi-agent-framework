{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Mood",
  "description": "Emotional state of the agent",
  "type": "object",
  "properties": {
    "mood": { "type": "string", "description": "Current mood label (e.g. happy, tired, playful)" },
    "emoji": { "type": "string", "description": "Emoji representing current mood" },
    "energy": { "type": "integer", "minimum": 0, "maximum": 100, "description": "Energy level 0-100" },
    "note": { "type": "string", "description": "Optional note or context about current state" },
    "updated": { "type": "string", "format": "date-time", "description": "ISO 8601 timestamp" }
  },
  "required": ["mood", "energy", "updated"]
}
