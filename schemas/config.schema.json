{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Config",
  "description": "Agent runtime configuration",
  "type": "object",
  "properties": {
    "model": { "type": "string", "description": "Ollama model name", "default": "qwen2.5:7b" },
    "base_url": { "type": "string", "description": "Ollama server URL", "default": "http://localhost:11434" },
    "temperature": { "type": "number", "minimum": 0, "maximum": 2, "default": 0.7 },
    "tools_enabled": { "type": "boolean", "default": true },
    "allowlist_path": { "type": "string", "description": "Path to command allowlist", "default": "tools/allowlist.txt" }
  },
  "required": ["model"]
}
